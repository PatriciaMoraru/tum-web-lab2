---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import Services from "../components/Services.astro";
import WhyUs from "../components/WhyUs.astro";
import Cta from "../components/Cta.astro";

const heroFileRaw = import.meta.glob("../content/hero.md", { eager: true });
const heroFile = Object.values(heroFileRaw)[0] as any;

const servicesHeaderRaw = import.meta.glob("../content/services-header.md", { eager: true });
const servicesHeaderFile = Object.values(servicesHeaderRaw)[0] as any;

const serviceFilesRaw = import.meta.glob("../content/services/*.md", { eager: true });
const services = Object.values(serviceFilesRaw)
  .map((file: any) => file.frontmatter)
  .sort((a: any, b: any) => a.order - b.order);

const whyUsRaw = import.meta.glob("../content/why-us.md", { eager: true });
const whyUsFile = Object.values(whyUsRaw)[0] as any;

const ctaRaw = import.meta.glob("../content/cta.md", { eager: true });
const ctaFile = Object.values(ctaRaw)[0] as any;
---

<Layout>
  <Header />

  <main>
    <Hero frontmatter={heroFile.frontmatter} />
    <Services header={servicesHeaderFile.frontmatter} services={services} />
    <WhyUs frontmatter={whyUsFile.frontmatter} />
    <Cta frontmatter={ctaFile.frontmatter} />
  </main>

  <Footer />
</Layout>