---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { formatBlogDate } from "../../utils/formatBlogDate";

export function getStaticPaths() {
  const blogFilesRaw = import.meta.glob("../../content/blog/*.md", { eager: true });
  const posts = Object.values(blogFilesRaw) as any[];

  return posts.map((post: any) => ({
    params: { slug: post.frontmatter.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = post;
---

<Layout title={`${post.frontmatter.title} — Dr. Aliona Starinschi`}>
  <Header />

  <main>
    <article class="pt-[4.8rem] pb-[9.6rem] bg-white">
      <div class="container" style="max-width: 80rem;">
        <a href="/#blog" class="link text-[1.6rem] mb-[3.2rem] inline-block">&larr; Înapoi la articole</a>

        <div class="mb-[3.2rem]">
          <span class="inline-block px-[0.8rem] py-[0.4rem] text-[1.2rem] uppercase text-white rounded-full font-semibold" style={`background-color: ${post.frontmatter.tagColor}`}>
            {post.frontmatter.tag}
          </span>
        </div>

        <h1 class="heading-primary mb-[2.4rem]">{post.frontmatter.title}</h1>

        <div class="flex gap-[2.4rem] text-[1.6rem] text-[#777] mb-[4.8rem]">
          <span class="flex items-center gap-[0.8rem]">
            <ion-icon name="calendar-outline"></ion-icon>
            {formatBlogDate(post.frontmatter.date)}
          </span>
          <span class="flex items-center gap-[0.8rem]">
            <ion-icon name="time-outline"></ion-icon>
            {post.frontmatter.readingTime}
          </span>
        </div>

        <img src={post.frontmatter.image} alt={post.frontmatter.imageAlt} class="w-full rounded-[11px] mb-[4.8rem]" />

        <div class="blog-post-content text-[1.8rem] leading-[1.8] text-[#333]">
          <Content />
        </div>
      </div>
    </article>
  </main>

  <Footer />
</Layout>

<style>
  .blog-post-content :global(h2) {
    font-size: 2.8rem;
    font-weight: 700;
    margin-top: 4rem;
    margin-bottom: 1.6rem;
    color: #333;
  }
  .blog-post-content :global(ul) {
    list-style: disc;
    padding-left: 3.2rem;
    margin-bottom: 2.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .blog-post-content :global(p) {
    margin-bottom: 2rem;
  }
</style>
